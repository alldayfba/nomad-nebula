{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prompt Contract",
  "description": "Schema for validating prompt contract YAML files",
  "type": "object",
  "required": ["name", "version", "description", "input", "output", "definition_of_done"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Snake_case contract identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "input": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["string", "number", "list", "object", "boolean"] },
                "description": { "type": "string" }
              }
            }
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["format", "sections"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["markdown", "json", "csv", "plaintext", "yaml"]
        },
        "sections": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "constraints": {
          "type": "object"
        }
      }
    },
    "definition_of_done": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "error_handling": {
      "type": "object",
      "properties": {
        "missing_input": { "type": "string" },
        "validation_fail": { "type": "string" },
        "partial_output": { "type": "string" }
      }
    }
  }
}
